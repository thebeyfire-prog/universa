{
  "name": "@universarails/agent-toolkit",
  "version": "0.1.0",
  "description": "Agent-safe Universa API client, tool wrappers, and MCP stdio server.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://universarails.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thebeyfire-prog/universa.git",
    "directory": "agent-toolkit"
  },
  "bugs": {
    "url": "https://github.com/thebeyfire-prog/universa/issues"
  },
  "keywords": [
    "universa",
    "agent",
    "mcp",
    "payments",
    "payouts",
    "stablecoin",
    "usdc",
    "kyc",
    "virtual-accounts"
  ],
  "files": [
    "README.md",
    "LICENSE",
    "src",
    "examples"
  ],
  "bin": {
    "universa-mcp": "src/mcp-server.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./client": "./src/client.mjs",
    "./tools": "./src/tools.mjs"
  },
  "scripts": {
    "check": "node --check src/client.mjs && node --check src/tools.mjs && node --check src/mcp-server.mjs && node --check src/index.mjs && node --check examples/create-va-dry-run.mjs",
    "smoke": "node scripts/smoke-agent-toolkit.mjs"
  }
}
