SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Local bootstrap tenant credentials.
BOOTSTRAP_TENANT_ID=ten_test_local
BOOTSTRAP_API_KEY=mk_test_local
BOOTSTRAP_API_SECRET=replace-with-a-long-random-secret

# mock | partner
PLATFORM_PROVIDER=mock
MOCK_AUTO_APPROVE_KYC=true

# Privy Solana server wallets for API customers.
# Use PRIVY_WALLET_MODE=mock locally. Use live with the Monet Privy Solana app
# credentials in deployed environments.
PRIVY_WALLET_MODE=mock
PRIVY_API_URL=https://api.privy.io/v1
PRIVY_SOL_APP_ID=
PRIVY_SOL_APP_SECRET=
PRIVY_AUTH_PUB_KEY=
PRIVY_AUTH_PRIV_KEY=

UNIVERSA_FEE_BPS=30
DEFAULT_TENANT_FEE_BPS=0
MAX_TENANT_FEE_BPS=300
ESTIMATED_PROVIDER_FEE_BPS=75
MAX_QUOTE_AMOUNT_UNITS=100000
QUOTE_TTL_SECONDS=300

# Set only after institutional partner approval.
PARTNER_API_URL=
PARTNER_API_KEY=
PARTNER_REDIRECT_URI=
